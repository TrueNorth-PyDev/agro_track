# ============================================================
# AgroTrack — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in real values for local dev.
# On Railway, set these in the service's "Variables" tab.
# NEVER commit the real .env file to version control.
# ============================================================


# ── Core Django ────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated. On Railway, add your *.railway.app domain.
# e.g. localhost,127.0.0.1,agrotrack-production.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1


# ── Database ───────────────────────────────────────────────
# Automatically injected by Railway's Postgres plugin.
# For local dev with Postgres, set this manually.
# Leave UNSET to use SQLite locally.
# DATABASE_URL=postgresql://user:password@host:5432/dbname


# ── CORS & CSRF ────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Comma-separated. Must include your Railway HTTPS domain in production.
# e.g. https://agrotrack-production.up.railway.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000


# ── Email ──────────────────────────────────────────────────
# Use console backend locally (prints OTPs to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP settings (for production / SMTP backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=AgroTrack <noreply@agrotrack.com>


# ── OTP ────────────────────────────────────────────────────
# OTP expiry in minutes (default: 10)
OTP_EXPIRY_MINUTES=10


# ── AWS S3 / Cloud Storage (For Image Uploads) ─────────────
# Required for Proof of Delivery (POD) image uploads in production
# Railway filesystem is ephemeral; without this, uploads are lost on deploy
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_QUERYSTRING_AUTH=True
